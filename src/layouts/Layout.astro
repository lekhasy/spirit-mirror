---
import '../styles/global.css';
const { title = 'Spirit Mirror — Discover World Cultures' } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#ff6ec7" />
		<title>{title}</title>
	</head>
	<body class="site-root">
		<header class="site-header" role="banner">
			<div class="site-header-inner">
				<a class="site-logo" href="/">Spirit Mirror</a>
				<div id="siteCurrent" class="site-current" aria-hidden="true"></div>
			</div>
		</header>
		<slot />
	</body>
</html>

<style>
	:root{
		--accent-1: #ff6ec7;
		--accent-2: #6ecbff;
		--accent-3: #ffd36e;
		--bg: linear-gradient(135deg,var(--accent-1),var(--accent-2));
		--glass: rgba(255,255,255,0.08);
	}
	html,body,.site-root{height:100%;margin:0}
</style>
