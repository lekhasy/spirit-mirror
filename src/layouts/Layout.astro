---
import '../styles/global.css';
const { title = 'Spirit Mirror — Discover World Cultures' } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#f5f8f4" />
		<title>{title}</title>
	</head>
	<body class="site-root">
		<header class="site-header" role="banner">
			<div class="site-header-inner">
				<a class="site-logo" href="/">Spirit Mirror</a>
				<nav class="site-nav">
					<a class="site-nav-link" href="/about">About</a>
				</nav>
				<div id="siteCurrent" class="site-current" aria-hidden="true"></div>
			</div>
		</header>
		<slot />
	</body>
</html>

<style>
	:root{
		--accent-1: #2d7a4a;
		--accent-2: #c47a15;
		--accent-3: #4a7a9a;
		--bg: #f5f8f4;
		--glass: rgba(255,255,255,0.8);
	}
	html,body,.site-root{height:100%;margin:0;background:#f5f8f4}
</style>
