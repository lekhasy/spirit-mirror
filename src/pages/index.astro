---
import Layout from '../layouts/Layout.astro';

const countries = [
  {
    name: 'Vietnam',
    native: 'Việt Nam',
    path: '/vietnam',
    image: 'https://images.unsplash.com/photo-1557750255-c76072a7aad1?q=80&w=2940&auto=format&fit=crop',
    tagline: '96M people · 4,000 years of history',
    description: 'Market flavors, river life, and a spirit forged through centuries of resilience.',
    accent: '#e8a020',
    bg: 'linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%)',
    pillars: ['History', 'Music', 'Belief', 'Festivals'],
    ready: true,
  },
  {
    name: 'Japan',
    native: '日本',
    path: '/japan',
    image: 'https://orizuruya.net/wp-content/uploads/2024/07/%E3%82%B9%E3%82%AF%E3%83%AA%E3%83%BC%E3%83%B3%E3%82%B7%E3%83%A7%E3%83%83%E3%83%88-2024-07-29-111659.png',
    tagline: '125M people · 2,600 years of tradition',
    description: 'Seasons, silence, and the beauty found in impermanence.',
    accent: '#bc002d',
    bg: 'linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%)',
    pillars: ['History', 'Music', 'Belief', 'Rituals'],
    ready: true,
  },
  {
    name: 'Brazil',
    native: 'Brasil',
    path: '/brazil',
    image: 'https://images.unsplash.com/photo-1700677866571-43199bcbc593?q=80&w=3430&auto=format&fit=crop',
    tagline: '215M people · 500 years of mixing',
    description: 'Rhythm, color, and a people who turn hardship into celebration.',
    accent: '#ffdf00',
    bg: 'linear-gradient(135deg, #e0f2f1 0%, #b2dfdb 100%)',
    pillars: ['Music', 'Festivals', 'Dance', 'Stories'],
    ready: true,
  },
  {
    name: 'Nigeria',
    native: 'Naìjíríà',
    path: '/nigeria',
    image: 'https://images.unsplash.com/photo-1618828665011-0abd973f7bb8?q=80&w=3432&auto=format&fit=crop',
    tagline: '220M people · 250+ ethnic groups',
    description: 'Bold textiles, griot storytelling, and the continent\'s creative heartbeat.',
    accent: '#008751',
    bg: 'linear-gradient(135deg, #e8f5e9 0%, #a5d6a7 100%)',
    pillars: ['Stories', 'Music', 'Belief', 'Rituals'],
    ready: true,
  },
  {
    name: 'India',
    native: 'भारत',
    path: '/india',
    image: 'https://images.unsplash.com/flagged/photo-1577604981316-298e453a19dd?q=80&w=2946&auto=format&fit=crop',
    tagline: '1.4B people · 5,000 years of civilization',
    description: 'A tapestry of languages, faiths, and festivals that defies easy description.',
    accent: '#ff9933',
    bg: 'linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%)',
    pillars: ['Belief', 'Festivals', 'Literature', 'Dance'],
    ready: true,
  },
  {
    name: 'United States',
    native: 'United States',
    path: '/united-states',
    image: 'https://images.unsplash.com/photo-1485738422979-f5c462d49f74?q=80&w=2940&auto=format&fit=crop',
    tagline: '335M people · A nation of immigrants',
    description: 'E pluribus unum. From many, one — a culture built on reinvention, dissent, and boundless ambition.',
    accent: '#3c3c6e',
    bg: 'linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%)',
    pillars: ['Stories', 'Music', 'Belief', 'Festivals'],
    ready: true,
  },
];

const themes = [
  { icon: '📜', label: 'History', desc: 'How the past shapes the present' },
  { icon: '👨‍👩‍👧', label: 'Parenting', desc: 'How children are raised' },
  { icon: '📖', label: 'Stories', desc: 'Myths, fables, and folk tales' },
  { icon: '🙏', label: 'Belief', desc: 'Faith, spirituality, and worldview' },
  { icon: '🪔', label: 'Rituals', desc: 'The ceremonies of life' },
  { icon: '🎆', label: 'Festivals', desc: 'Celebrations across the year' },
  { icon: '🎵', label: 'Music', desc: 'Sound and soul across time' },
  { icon: '✍️', label: 'Literature', desc: 'Words that carry a culture' },
  { icon: '💃', label: 'Dance', desc: 'Movement as expression' },
];
---

<Layout title="Spirit Mirror — Discover World Cultures">

<!-- Nav override -->
<style is:global>
  .site-header {
    background: rgba(255,255,255,0.92) !important;
    backdrop-filter: blur(12px) !important;
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 200 !important;
    border-bottom: 1px solid rgba(0,80,0,0.1) !important;
    box-shadow: 0 1px 8px rgba(0,0,0,0.06) !important;
  }
  .site-logo { color: #1a5c2a !important; font-size: 1.1rem !important; font-weight: 700 !important; letter-spacing: 0.04em !important; }
  .site-root { background: #f5f8f4 !important; }
</style>

<!-- ① HERO -->
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
  </div>
  <div class="hero-inner">
    <p class="hero-eyebrow">🌍 Spirit Mirror</p>
    <h1 class="hero-h1">Every culture has<br/><em>a story to tell.</em></h1>
    <p class="hero-sub">Step beyond borders. Explore the beliefs, rituals, music, and history that make each people who they are — told through the cultural elements that shape every human life.</p>
    <div class="hero-actions">
      <a href="#countries" class="btn-primary">Start Exploring →</a>
      <a href="#themes" class="btn-ghost">Browse by Theme</a>
    </div>
    <p class="hero-hint">6 cultures · exploring what makes each culture unique</p>
  </div>
  <div class="hero-wave" aria-hidden="true"></div>
</section>

<!-- ② COUNTRIES -->
<section class="countries" id="countries">
  <div class="section-header">
    <h2 class="section-title">Choose a Culture</h2>
    <p class="section-sub">Each country is a doorway. Pick one and start exploring.</p>
  </div>

  <div class="country-grid">
    {countries.map((c) => (
      <a href={c.path} class={`country-card${c.ready ? '' : ' coming-soon'}`} style={`--card-accent: ${c.accent};`}>
        <div class="card-img-wrap">
          <img src={c.image} alt={c.name} class="card-img" loading="lazy" />
          <div class="card-img-overlay" style={`background: ${c.bg};`}></div>
          {!c.ready && <span class="card-badge">Coming soon</span>}
        </div>
        <div class="card-body">
          <div class="card-names">
            <span class="card-native">{c.native}</span>
            <span class="card-name">{c.name}</span>
          </div>
          <p class="card-tagline">{c.tagline}</p>
          <p class="card-desc">{c.description}</p>
          <div class="card-elements">
            {c.pillars.map(p => <span class="card-pill">{p}</span>)}
          </div>
          <div class="card-cta">
            {c.ready ? 'Explore culture →' : 'Coming soon'}
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ③ THEMES -->
<section class="themes" id="themes">
  <div class="section-header">
    <h2 class="section-title">Explore by Theme</h2>
    <p class="section-sub">Curious about how cultures approach music? Or how children are raised across the world? Start with a theme.</p>
  </div>
  <div class="theme-row">
    {themes.map(t => (
      <a href={`/vietnam#element-${t.label.toLowerCase()}`} class="theme-card">
        <span class="theme-icon">{t.icon}</span>
        <span class="theme-label">{t.label}</span>
        <span class="theme-desc">{t.desc}</span>
      </a>
    ))}
  </div>
</section>

<!-- ④ WHY -->
<section class="why">
  <div class="why-inner">
    <h2 class="section-title">A different kind of cultural guide</h2>
    <p class="section-sub">Not a travel blog. Not a Wikipedia summary. Something deeper.</p>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">🧭</div>
        <h3>Built around understanding, not tourism</h3>
        <p>We explore the cultural elements that shape how people think — parenting, belief, stories, rituals — not just landmarks and food.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">⏳</div>
        <h3>History as a living thread</h3>
        <p>Every cultural element is shown as a living timeline. See how Vietnamese music evolved from Bronze Age drums to V-Pop. Context changes everything.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🎨</div>
        <h3>Every culture, its own identity</h3>
        <p>Japan doesn't look like Vietnam. Brazil doesn't look like Nigeria. Each page is designed to feel like that culture, not a template.</p>
      </div>
    </div>
  </div>
</section>

<!-- ⑤ FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <span class="footer-logo">Spirit Mirror</span>
    <p class="footer-copy">Exploring cultures, one story at a time.</p>
  </div>
</footer>

</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;0,900;1,400&display=swap');

  *, *::before, *::after { box-sizing: border-box; }

  /* ── Tokens ─────────────────────────────────── */
  :root {
    --bg: #f5f8f4;
    --bg2: #edf3ed;
    --bg3: #e4ede4;
    --white: #ffffff;
    --muted: rgba(30,50,30,0.6);
    --border: rgba(0,60,0,0.1);
    --accent: #2d7a4a;
    --accent2: #c47a15;
    --text: #1a1a1a;
  }

  /* ── Base ───────────────────────────────────── */
  .hero, .countries, .themes, .why, .footer {
    font-family: 'Inter', sans-serif;
  }

  /* ── Hero ───────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 100px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.25;
  }
  .hero-orb-1 { width: 600px; height: 600px; background: #a5d6a7; top: -100px; left: -150px; }
  .hero-orb-2 { width: 400px; height: 400px; background: #c5cae9; top: 20%; right: -100px; }
  .hero-orb-3 { width: 500px; height: 300px; background: #ffe0b2; bottom: 0; left: 30%; }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 24px;
  }

  .hero-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.08;
    color: #1a1a1a;
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(30,50,30,0.65);
    max-width: 580px;
    margin: 0 auto 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 16px rgba(45,122,74,0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(45,122,74,0.4);
  }

  .btn-ghost {
    display: inline-block;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 14px 28px;
    border-radius: 100px;
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(45,122,74,0.05);
  }

  .hero-hint {
    font-size: 0.75rem;
    color: rgba(30,50,30,0.35);
    letter-spacing: 0.08em;
    margin: 0;
  }

  .hero-wave {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 80px;
    background: #edf3ed;
    clip-path: ellipse(60% 100% at 50% 100%);
  }

  /* ── Section shared ─────────────────────────── */
  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .section-sub {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Countries ──────────────────────────────── */
  .countries {
    background: #edf3ed;
    padding: 96px 24px;
  }

  .country-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .country-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    background: #ffffff;
    border: 1px solid var(--border);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .country-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    border-color: var(--card-accent, rgba(45,122,74,0.3));
  }

  .country-card.coming-soon {
    opacity: 0.6;
    pointer-events: none;
  }

  .card-img-wrap {
    position: relative;
    height: 180px;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .country-card:hover .card-img {
    transform: scale(1.05);
  }

  .card-img-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    mix-blend-mode: multiply;
  }

  .card-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255,255,255,0.9);
    color: rgba(30,50,30,0.8);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    border: 1px solid rgba(0,60,0,0.1);
  }

  .card-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-names {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }

  .card-native {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1;
  }

  .card-name {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-tagline {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--card-accent, #2d7a4a);
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(30,50,30,0.6);
    margin: 0 0 16px;
    flex: 1;
  }

  .card-elements {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .card-pill {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(30,50,30,0.55);
    background: rgba(45,122,74,0.06);
    border: 1px solid rgba(45,122,74,0.15);
    border-radius: 100px;
    padding: 3px 10px;
  }

  .card-cta {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--card-accent, #2d7a4a);
    letter-spacing: 0.03em;
    transition: gap 0.2s;
  }

  /* ── Themes ─────────────────────────────────── */
  .themes {
    background: var(--bg);
    padding: 96px 24px;
  }

  .theme-row {
    display: flex;
    overflow-x: auto;
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 8px;
    scrollbar-width: none;
  }
  .theme-row::-webkit-scrollbar { display: none; }

  .theme-card {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    padding: 24px 20px;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    width: 130px;
    transition: all 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  .theme-card:hover {
    background: var(--bg);
    border-color: rgba(45,122,74,0.3);
    transform: translateY(-3px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .theme-icon {
    font-size: 1.8rem;
    line-height: 1;
  }

  .theme-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: 0.02em;
  }

  .theme-desc {
    font-size: 0.68rem;
    color: var(--muted);
    line-height: 1.4;
  }

  /* ── Why ────────────────────────────────────── */
  .why {
    background: #e4ede4;
    padding: 96px 24px;
  }

  .why-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    margin-top: 56px;
    text-align: left;
  }

  .why-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 28px 32px;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  .why-card:hover {
    border-color: rgba(45,122,74,0.3);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .why-icon {
    font-size: 2rem;
    margin-bottom: 16px;
  }

  .why-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 12px;
    line-height: 1.35;
  }

  .why-card p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: rgba(30,50,30,0.5);
    margin: 0;
  }

  /* ── Footer ─────────────────────────────────── */
  .footer {
    background: #e4ede4;
    padding: 40px 24px;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a5c2a;
    letter-spacing: 0.04em;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(30,50,30,0.4);
    margin: 0;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 640px) {
    .country-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; align-items: center; }
    .footer-inner { flex-direction: column; text-align: center; }
  }
</style>

