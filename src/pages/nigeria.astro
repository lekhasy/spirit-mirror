---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div style="min-height:100vh;background:#0b3d2e;color:#fff;padding-bottom:80px">
    <header style="padding:48px 6vw;display:flex;justify-content:space-between;align-items:center">
      <div>
        <h1 style="margin:0;font-size:48px">Nigeria</h1>
        <p style="margin:6px 0 0">Bold textiles, storytelling and a vibrant contemporary arts scene.</p>
      </div>
      <a href="/" style="background:#ffd36e;color:#0b3d2e;padding:8px 12px;border-radius:8px;text-decoration:none">Back</a>
    </header>

    <section style="padding:36px 6vw;display:grid;grid-template-columns:repeat(3,1fr);gap:18px">
      <div style="background:#14443b;padding:18px;border-radius:8px">Textiles & fashion</div>
      <div style="background:#14443b;padding:18px;border-radius:8px">Music & film</div>
      <div style="background:#14443b;padding:18px;border-radius:8px">Cuisine & markets</div>
    </section>
  </div>
</Layout>
