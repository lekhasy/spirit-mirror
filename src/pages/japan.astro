---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main style="min-height:100vh;"> 
    <section class="country-header" style="background:linear-gradient(180deg,rgba(2,6,23,0.6),rgba(255,255,255,0.02));">
      <div style="flex:1;">
        <h1 style="font-size:48px;margin:0">Japan</h1>
        <p style="margin-top:12px;max-width:60%">A deep culture of refinement — from tea ceremony to seasonal festivals and delicate craft.</p>
        <a href="/" style="margin-top:18px;display:inline-block;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.9);text-decoration:none;color:#111;font-weight:700">Back</a>
      </div>
      <div style="width:320px;text-align:right;opacity:0.95">
        <div style="font-size:14px">Population</div>
        <div style="font-size:22px;font-weight:700">125M</div>
      </div>
    </section>

    <section class="country-hero" style="background-image:url('https://images.unsplash.com/photo-1549692520-acc6669e2f0c?q=80&w=1600&auto=format&fit=crop');">
      <div style="padding:28px;color:white;text-shadow:0 3px 12px rgba(0,0,0,0.5);">
        <h2 style="margin:0 0 6px">Tradition & Craft</h2>
        <p style="margin:0;max-width:55%">From woodblock prints to tea houses, discover the small experiences that shape daily life.</p>
      </div>
    </section>

    <section style="padding:48px 6vw;display:grid;grid-template-columns:1fr 1fr;gap:32px">
      <article style="background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));padding:22px;border-radius:12px;">
        <h3>Tea & Ceremony</h3>
        <p>Learn how the ritual of serving tea reflects precision, hospitality and seasonal sensitivity.</p>
      </article>
      <article style="background:rgba(255,255,255,0.02);padding:22px;border-radius:12px;">
        <h3>Festivals</h3>
        <p>From cherry blossom hanami to summer lantern festivals, public celebration is richly local.</p>
      </article>
    </section>
  </main>
</Layout>
