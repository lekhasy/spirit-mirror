    transform: translateY(-2px);
  }

  /* Asanoha corner accent — very subtle geometric pattern */
  .jp-card-asanoha {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 36px;
    height: 32px;
    pointer-events: none;
    opacity: 0.6;
  }

  .jp-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .jp-card-period {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--jp-vermillion);
    background: rgba(196, 30, 58, 0.05);
    border: 1px solid rgba(196, 30, 58, 0.12);
    border-radius: 2px;
    padding: 3px 12px;
  }

  .jp-card-era {
    font-family: var(--font-body);
    font-size: 0.70rem;
    color: var(--jp-warm-gray);
    font-weight: 400;
  }

  .jp-card-title {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    font-weight: 700;
    color: var(--jp-sumi);
    margin: 0 0 12px;
    line-height: 1.35;
  }

  .jp-card-summary {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.88;
    color: rgba(26, 23, 20, 0.72);
    margin: 0 0 14px;
    font-weight: 400;
    flex: 1;
  }

  .jp-card-content {
    font-family: var(--font-body);
    font-size: 0.84rem;
    line-height: 1.85;
    color: rgba(26, 23, 20, 0.78);
    border-top: 1px solid var(--jp-pale-sand);
    padding-top: 14px;
    margin-bottom: 14px;
    overflow: hidden;
  }

  .jp-card-content p { margin: 0; }

  .jp-card-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--jp-vermillion);
    padding: 0;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
    align-self: flex-start;
  }

  .jp-card-toggle:hover {
    color: var(--jp-gold);
  }

  /* Plus/X toggle icon */
  .jp-toggle-icon {
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.25s var(--ease-arrival);
    position: relative;
  }

  .jp-toggle-icon::before,
  .jp-toggle-icon::after {
    content: '';
    position: absolute;
    background: var(--jp-white);
    border-radius: 2px;
  }
  .jp-toggle-icon::before {
    width: 7px;
    height: 1.5px;
  }
  .jp-toggle-icon::after {
    width: 1.5px;
    height: 7px;
    transition: transform 0.25s var(--ease-arrival);
  }

  .jp-card-toggle[aria-expanded="true"] .jp-toggle-icon::after {
    transform: rotate(90deg);
  }

  /* ── CALLOUT BOX — Ainu & Okinawa ────────────────────────── */
  .jp-callout {
    margin-top: 96px;
    padding: 0 4px;
  }

  .jp-callout-inner {
    position: relative;
    border: 1px solid rgba(27, 42, 74, 0.18);
    border-radius: 3px;
    padding: 28px 34px;
    background: rgba(27, 42, 74, 0.02);
    overflow: hidden;
  }

  /* Seigaiha wave pattern at top */
  .jp-callout-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      rgba(27, 42, 74, 0.15) 0px,
      rgba(27, 42, 74, 0.15) 8px,
      transparent 8px,
      transparent 16px
    );
  }

  .jp-callout-wave {
    position: absolute;
    top: 0;
    right: 0;
    width: 110px;
    pointer-events: none;
  }

  .jp-callout-label {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--jp-shikon);
    margin: 0 0 10px;
    opacity: 0.80;
  }

  .jp-callout-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.82;
    color: rgba(27, 42, 74, 0.70);
    margin: 0;
  }

  .jp-callout-text strong {
    color: rgba(27, 42, 74, 0.88);
    font-weight: 600;
  }

  /* ── FOOTER ───────────────────────────────────────────────── */
  .jp-footer {
    background: var(--jp-cream);
    padding: 52px 24px;
    border-top: 1px solid rgba(232, 221, 208, 0.6);
    position: relative;
    overflow: hidden;
  }

  /* Torii silhouette — stroke only, nearly invisible */
  .jp-footer-torii {
    position: absolute;
    top: 50%;
    right: 7%;
    transform: translateY(-50%);
    width: 68px;
    color: var(--jp-vermillion);
    pointer-events: none;
    opacity: 0.07;
  }

  .jp-footer-inner {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .jp-footer-logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--jp-vermillion);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.2s ease;
  }

  .jp-footer-logo:hover {
    color: var(--jp-vermillion-deep);
  }

  .jp-footer-copy {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--jp-warm-gray);
    margin: 0;
  }

  .jp-footer-back {
    font-family: var(--font-body);
    font-size: 0.78rem;
