<script>
  // Tab switching
  document.querySelectorAll('.jp-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.jp-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const target = tab.dataset.pillar;
      document.querySelectorAll('.jp-pillar').forEach(p => {
        const active = p.id === `element-${target}`;
        p.classList.toggle('active', active);
        p.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      observeCards();
    });
  });

  // Expand / collapse with smooth height transition
  document.querySelectorAll('.jp-card-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.closest('.jp-card').querySelector('.jp-card-content');
      const open = btn.getAttribute('aria-expanded') === 'true';
      content.hidden = open;
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      btn.querySelector('.jp-toggle-text').textContent = open ? 'Continue reading' : 'Read less';
    });
  });

  // Scroll animation
  let observer;
  function observeCards() {
    if (observer) observer.disconnect();
    observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -24px 0px' });

    document.querySelectorAll('.jp-pillar.active .jp-card-wrap:not(.visible)')
      .forEach(c => observer.observe(c));
  }

  observeCards();

  // Fade scroll indicator on scroll
  const scrollIndicator = document.querySelector('.jp-hero-scroll');
  if (scrollIndicator) {
    window.addEventListener('scroll', () => {
      const opacity = Math.max(0, 1 - window.scrollY / 200);
      scrollIndicator.style.opacity = opacity.toString();
    }, { passive: true });
  }
</script>
