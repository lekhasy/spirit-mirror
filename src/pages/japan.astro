      height: 30px;
    }

    .jp-footer-inner {
      flex-direction: column;
      text-align: center;
    }
    .jp-footer-torii {
      display: none;
    }

    .jp-h1-kanji {
      font-size: clamp(3.8rem, 22vw, 7rem);
    }

    .jp-callout-inner {
      padding: 22px 24px;
    }

    .jp-main {
      padding: 64px 16px 80px;
    }

    .jp-section-divider {
      margin-bottom: 56px;
    }

    .jp-card {
      padding: 22px 22px;
    }
  }

  @media (max-width: 380px) {
    .jp-card {
      padding: 18px 18px;
    }
    .jp-hero-inner {
      padding-top: 4vh;
    }
  }
</style>

<script>
  // ═══════════════════════════════════════════════════════════
  // TAB SWITCHING — deliberate, breath-like transition
  // ═══════════════════════════════════════════════════════════
  document.querySelectorAll('.jp-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      // Update tab states
      document.querySelectorAll('.jp-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      // Fade out current pillar
      const currentPillar = document.querySelector('.jp-pillar.active');
      if (currentPillar) {
        currentPillar.style.opacity = '0';
        currentPillar.style.transform = 'translateY(-8px)';
        currentPillar.classList.remove('active');
        currentPillar.setAttribute('aria-hidden', 'true');
      }

      // Show new pillar after brief pause
      const targetId = `element-${tab.dataset.pillar}`;
      const targetPillar = document.getElementById(targetId);
      
      setTimeout(() => {
        if (targetPillar) {
          targetPillar.style.opacity = '';
          targetPillar.style.transform = '';
          targetPillar.classList.add('active');
          targetPillar.setAttribute('aria-hidden', 'false');
          observeCards();
          // Scroll to top of pillar
          targetPillar.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 120);
    });
  });

  // ═══════════════════════════════════════════════════════════
  // CARD EXPAND / COLLAPSE — smooth unrolling
  // ═══════════════════════════════════════════════════════════
  document.querySelectorAll('.jp-card-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.jp-card');
      const content = card.querySelector('.jp-card-content');
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';

      if (!isExpanded) {
        // Expand — reveal content
        content.hidden = false;
        content.style.maxHeight = content.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('.jp-toggle-text').textContent = 'Read less';
      } else {
        // Collapse
        content.style.maxHeight = '0';
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.jp-toggle-text').textContent = 'Continue reading';
        setTimeout(() => {
          content.hidden = true;
          content.style.maxHeight = '';
        }, 320);
      }
    });
  });

  // ═══════════════════════════════════════════════════════════
  // SCROLL ANIMATION — cards arrive like scrolls being unrolled
  // ═══════════════════════════════════════════════════════════
  let observer;
  
  function observeCards() {
    if (observer) observer.disconnect();
    
    observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, {
    threshold: 0.05,
    rootMargin: '0px 0px -20px 0px'
    });

    const activePillar = document.querySelector('.jp-pillar.active');
    if (activePillar) {
      activePillar.querySelectorAll('.jp-card-wrap:not(.visible)')
        .forEach((c, i) => {
          // Stagger cards within same section
          (c as HTMLElement).style.transitionDelay = `${i * 55}ms`;
          observer.observe(c);
        });
    }
  }

  // Initial observation
  observeCards();

  // ═══════════════════════════════════════════════════════════
  // SCROLL INDICATOR — fades as user scrolls
  // ═══════════════════════════════════════════════════════════
  const scrollIndicator = document.querySelector('.jp-hero-scroll');
  if (scrollIndicator) {
    window.addEventListener('scroll', () => {
      const opacity = Math.max(0, 1 - window.scrollY / 180);
      (scrollIndicator as HTMLElement).style.opacity = opacity.toString();
    }, { passive: true });
  }

  // ═══════════════════════════════════════════════════════════
  // PILLAR SECTION TRANSITIONS — smooth opacity
  // ═══════════════════════════════════════════════════════════
  // Make all pillars transition-ready
  document.querySelectorAll('.jp-pillar').forEach(p => {
    (p as HTMLElement).style.transition = 'opacity 0.28s var(--ease-departure), transform 0.28s var(--ease-departure)';
  });
</script>
