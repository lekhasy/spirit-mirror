  }

  /* ── MOBILE RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 640px) {
    .jp-timeline-line {
      left: 16px;
    }

    .jp-card-wrap.left,
    .jp-card-wrap.right {
      flex-direction: column;
      padding-left: 44px;
      padding-right: 0;
    }

    .jp-card {
      max-width: 100%;
      aspect-ratio: auto;
      max-height: none;
      min-height: 0;
    }

    .jp-timeline-node {
      left: 16px;
      top: 20px;
    }

    .jp-tab-label {
      display: none;
    }
    .jp-tab {
      padding: 15px 16px;
    }
    .jp-tab-icon {
      font-size: 1.05rem;
    }

    .jp-pillar-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .jp-pillar-icon-lg {
