    border-left: 3px solid var(--jp-vermillion);
    border-radius: 2px 4px 2px 2px;
    padding: 26px 30px;
    width: 100%;
    max-width: 500px;
    /* Horizontal tatami ratio — wider than tall */
    aspect-ratio: 3 / 2.1;
    max-height: 280px;
