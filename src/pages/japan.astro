  /* ── TIMELINE ─────────────────────────────────────────────── */
  .jp-timeline {
    position: relative;
  }

  /* Timeline line — fades at top and bottom */
  .jp-timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--jp-washi-dark) 8%,
      var(--jp-washi-dark) 92%,
      transparent 100%
    );
    transform: translateX(-50%);
  }

  /* Card wrapper */
  .jp-card-wrap {
    position: relative;
    display: flex;
    margin-bottom: 60px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s var(--ease-arrival), transform 0.4s var(--ease-arrival);
  }

  .jp-card-wrap.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* First card in section gets "unroll" treatment */
  .jp-card-wrap.first-in-section.visible {
    animation: jp-card-unroll 450ms var(--ease-arrival) both;
  }

  @keyframes jp-card-unroll {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .jp-card-wrap.left {
    padding-right: calc(50% + 40px);
  }

  .jp-card-wrap.right {
    flex-direction: row-reverse;
    padding-left: calc(50% + 40px);
  }

  /* Timeline node */
  .jp-timeline-node {
    position: absolute;
    left: 50%;
    top: 24px;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .jp-node-outer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid var(--jp-vermillion);
