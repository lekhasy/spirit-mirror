---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div style="min-height:100vh;background:linear-gradient(180deg,#ff9a9e,#fecfef);color:#3b0b2e">
    <header style="padding:56px 6vw;display:flex;justify-content:space-between;align-items:center">
      <div>
        <h1 style="margin:0;font-size:48px">India</h1>
        <p style="margin:8px 0 0">A tapestry of languages, religions, food, and festivals across regions and seasons.</p>
      </div>
      <a href="/" style="background:#3b0b2e;color:#fff;padding:8px 12px;border-radius:8px;text-decoration:none">Home</a>
    </header>

    <section style="padding:24px 6vw;display:flex;gap:18px;align-items:flex-start">
      <div style="flex:1;background-image:url('https://images.unsplash.com/photo-1505250469679-203ad9ced0cb?q=80&w=1200&auto=format&fit=crop');background-size:cover;border-radius:16px;min-height:44vh"></div>
      <div style="flex:1;display:flex;flex-direction:column;gap:12px">
        <div style="background:rgba(255,255,255,0.9);padding:14px;border-radius:12px">Festivals: Holi, Diwali, regional fairs</div>
        <div style="background:rgba(255,255,255,0.9);padding:14px;border-radius:12px">Culinary diversity by state and climate</div>
      </div>
    </section>
  </div>
</Layout>
