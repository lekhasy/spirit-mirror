---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div style="min-height:100vh;background:linear-gradient(90deg,#1bd760,#ffe66d);color:#072a12;padding-bottom:60px">
    <nav style="display:flex;justify-content:space-between;align-items:center;padding:28px 6vw">
      <div style="font-weight:800;font-size:20px">Brazil</div>
      <a href="/" style="text-decoration:none;color:#072a12;background:white;padding:8px 12px;border-radius:8px">Home</a>
    </nav>

    <header style="padding:12px 6vw;">
      <h1 style="font-size:56px;margin:6px 0">Carnival & Coast</h1>
      <p style="max-width:60%">Lively, rhythmic, and full of color — Brazil's culture connects music, dance, and community.</p>
    </header>

    <section style="display:flex;gap:20px;padding:32px 6vw">
      <div style="flex:2;background-image:url('https://images.unsplash.com/photo-1544025162-d76694265947?q=80&w=1600&auto=format&fit=crop');background-size:cover;border-radius:12px;min-height:42vh"></div>
      <aside style="flex:1;display:flex;flex-direction:column;gap:12px">
        <div style="background:rgba(255,255,255,0.9);padding:14px;border-radius:10px">Music: Samba, Bossa Nova</div>
        <div style="background:rgba(255,255,255,0.9);padding:14px;border-radius:10px">Food: Feijoada & street snacks</div>
      </aside>
    </section>
  </div>
</Layout>
