---
import Layout from '../layouts/Layout.astro';
import data from '../data/brazil.json';
const pillars = data.pillars;
---

<Layout title="Brazil — Spirit Mirror">

<!-- Hero -->
<section class="br-hero">
  <div class="br-hero-bg" aria-hidden="true">
    <div class="br-hero-sun"></div>
    <div class="br-hero-waves"></div>
  </div>
  <div class="br-hero-inner">
    <div class="br-hero-tag">🇧🇷 Culture · Heritage · Identity</div>
    <h1 class="br-hero-title">
      <span class="br-h1-brasil">Brasil</span>
    </h1>
    <p class="br-hero-subtitle">Five hundred years of mixing, rhythm, and joy — explored through nine pillars that define Brazil's extraordinary cultural synthesis.</p>
    <div class="br-hero-stats">
      <div class="br-stat"><span class="br-stat-n">215M</span><span class="br-stat-l">People</span></div>
      <div class="br-stat-divider" aria-hidden="true"></div>
      <div class="br-stat"><span class="br-stat-n">500+</span><span class="br-stat-l">Years of Mixing</span></div>
      <div class="br-stat-divider" aria-hidden="true"></div>
      <div class="br-stat"><span class="br-stat-n">9</span><span class="br-stat-l">Cultural Pillars</span></div>
    </div>
  </div>
  <div class="br-hero-scroll" aria-hidden="true">
    <span>Scroll to explore</span>
    <span class="br-scroll-arrow">↓</span>
  </div>
</section>

<!-- Pillar Navigation -->
<nav class="br-tabs" aria-label="Culture pillars">
  <div class="br-tabs-inner">
    {pillars.map((p, i) => (
      <button
        class={`br-tab${i === 0 ? ' active' : ''}`}
        data-pillar={p.id}
        aria-selected={i === 0 ? 'true' : 'false'}
      >
        <span class="br-tab-icon">{p.icon}</span>
        <span class="br-tab-label">{p.title}</span>
      </button>
    ))}
  </div>
</nav>

<!-- Content -->
<main class="br-main">
  {pillars.map((p, pi) => (
    <section
      class={`br-pillar${pi === 0 ? ' active' : ''}`}
      id={`pillar-${p.id}`}
      aria-hidden={pi !== 0 ? 'true' : 'false'}
    >
      <div class="br-pillar-header">
        <div class="br-pillar-header-left">
          <span class="br-pillar-number">0{pi + 1}</span>
          <div>
            <h2 class="br-pillar-title">{p.title}</h2>
            <p class="br-pillar-sub">{p.entries.length} chapters across time</p>
          </div>
        </div>
        <span class="br-pillar-icon-lg">{p.icon}</span>
      </div>

      <div class="br-timeline">
        <div class="br-timeline-line" aria-hidden="true"></div>
        {p.entries.map((entry, ei) => (
          <div class={`br-card-wrap ${ei % 2 === 0 ? 'left' : 'right'}`}>
            <div class="br-timeline-node" aria-hidden="true">
              <div class="br-node-outer"></div>
              <div class="br-node-inner"></div>
            </div>
            <article class="br-card">
              <div class="br-card-top">
                <span class="br-card-period">{entry.period}</span>
                <span class="br-card-era">{entry.era}</span>
              </div>
              <h3 class="br-card-title">{entry.title}</h3>
              <p class="br-card-summary">{entry.summary}</p>
              <div class="br-card-content" hidden>
                <p>{entry.content}</p>
              </div>
              <button class="br-card-toggle" aria-expanded="false">
                <span class="br-toggle-text">Read more</span>
                <span class="br-toggle-icon" aria-hidden="true"></span>
              </button>
            </article>
          </div>
        ))}
      </div>
    </section>
  ))}
</main>

<footer class="br-footer">
  <div class="br-footer-inner">
    <a href="/" class="br-footer-logo">Spirit Mirror</a>
    <p class="br-footer-copy">Exploring cultures, one story at a time.</p>
    <a href="/" class="br-footer-back">← All Cultures</a>
  </div>
</footer>

</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:ital,wght@0,700;0,900;1,400&display=swap');

  /* ── Variables ─────────────────────────────── */
  :root {
    --br-green: #1a5c2a;
    --br-green-dark: #0a2e18;
    --br-green-mid: #2d7a3a;
    --br-gold: #f2c94c;
    --br-gold-dark: #c9a84c;
    --br-blue: #1a4a7a;
    --br-white: #f8f9f7;
    --br-warm: #fdf6e3;
    --br-bg: #f5f0e0;
    --br-text: #1a1714;
    --br-muted: #6b6560;
    --br-border: #e0dbd0;
    --br-node: #f2c94c;
  }

  /* ── Global overrides ───────────────────────── */
  :global(.site-root) {
    background: var(--br-bg) !important;
  }
  :global(.site-header) {
    background: var(--br-green-dark) !important;
    border-bottom: 1px solid rgba(255,255,255,0.06) !important;
  }
  :global(.site-logo) {
    color: var(--br-gold) !important;
    font-family: 'Playfair Display', serif !important;
    letter-spacing: 0.02em !important;
  }

  /* ── Hero ───────────────────────────────────── */
  .br-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 80px 24px 120px;
    overflow: hidden;
    background: var(--br-green-dark);
  }

  .br-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .br-hero-sun {
    position: absolute;
    bottom: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(242, 201, 76, 0.25) 0%, rgba(242, 201, 76, 0.05) 60%, transparent 80%);
  }

  .br-hero-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, rgba(242, 201, 76, 0.15), transparent);
    clip-path: polygon(0 60%, 20% 30%, 40% 60%, 60% 20%, 80% 50%, 100% 30%, 100% 100%, 0% 100%);
  }

  .br-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .br-hero-tag {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--br-gold);
    border: 1px solid rgba(242, 201, 76, 0.35);
    border-radius: 100px;
    padding: 6px 18px;
    margin-bottom: 32px;
  }

  .br-hero-title {
    margin: 0 0 28px;
    display: block;
  }

  .br-h1-brasil {
    font-family: 'Playfair Display', serif;
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: 900;
    color: var(--br-gold);
    line-height: 1;
    letter-spacing: 0.04em;
    text-shadow: 0 0 60px rgba(242, 201, 76, 0.3);
  }

  .br-hero-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.95rem, 2.2vw, 1.05rem);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(248, 249, 247, 0.55);
    max-width: 560px;
    margin: 0 auto 52px;
  }

  .br-hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .br-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .br-stat-n {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .br-stat-l {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248, 249, 247, 0.35);
  }

  .br-stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(248, 249, 247, 0.12);
  }

  .br-hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(248, 249, 247, 0.25);
    z-index: 1;
  }

  .br-scroll-arrow {
    animation: br-bounce 1.6s ease-in-out infinite;
    display: block;
  }

  @keyframes br-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ── Tabs ───────────────────────────────────── */
  .br-tabs {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 46, 24, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(242, 201, 76, 0.1);
  }

  .br-tabs-inner {
    display: flex;
    overflow-x: auto;
    max-width: 1100px;
    margin: 0 auto;
    scrollbar-width: none;
    padding: 0 8px;
  }
  .br-tabs-inner::-webkit-scrollbar { display: none; }

  .br-tab {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(248, 249, 247, 0.4);
    transition: all 0.2s;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .br-tab:hover {
    color: rgba(248, 249, 247, 0.8);
  }

  .br-tab.active {
    color: var(--br-gold);
    border-bottom-color: var(--br-gold);
  }

  .br-tab-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* ── Main ───────────────────────────────────── */
  .br-main {
    max-width: 960px;
    margin: 0 auto;
    padding: 72px 24px 96px;
  }

  .br-pillar { display: none; }
  .br-pillar.active {
    display: block;
    animation: br-in 0.35s ease;
  }

  @keyframes br-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Pillar header */
  .br-pillar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 64px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--br-border);
  }

  .br-pillar-header-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .br-pillar-number {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--br-border);
    line-height: 1;
    user-select: none;
  }

  .br-pillar-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--br-text);
    margin: 0 0 4px;
    line-height: 1.1;
  }

  .br-pillar-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: var(--br-muted);
    margin: 0;
    letter-spacing: 0.03em;
  }

  .br-pillar-icon-lg {
    font-size: 3rem;
    opacity: 0.12;
    user-select: none;
  }

  /* ── Timeline ───────────────────────────────── */
  .br-timeline {
    position: relative;
  }

  .br-timeline-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--br-border) 5%, var(--br-border) 95%, transparent);
    transform: translateX(-50%);
  }

  .br-card-wrap {
    position: relative;
    display: flex;
    margin-bottom: 56px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .br-card-wrap.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .br-card-wrap.left {
    padding-right: calc(50% + 36px);
  }

  .br-card-wrap.right {
    flex-direction: row-reverse;
    padding-left: calc(50% + 36px);
  }

  .br-card-wrap.left .br-card {
    text-align: right;
  }

  .br-card-wrap.left .br-card-top {
    justify-content: flex-end;
  }

  .br-card-wrap.left .br-card-toggle {
    margin-left: auto;
  }

  /* Node */
  .br-timeline-node {
    position: absolute;
    left: 50%;
    top: 22px;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .br-node-outer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--br-green);
    background: var(--br-bg);
    transition: transform 0.2s;
  }

  .br-card-wrap:hover .br-node-outer {
    transform: scale(1.3);
  }

  .br-node-inner {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--br-green);
    position: relative;
    z-index: 1;
  }

  /* ── Card ───────────────────────────────────── */
  .br-card {
    background: var(--br-white);
    border: 1px solid var(--br-border);
    border-radius: 12px;
    padding: 24px 28px;
    width: 100%;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05), 0 4px 16px rgba(0,0,0,0.04);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    border-top: 4px solid var(--br-green);
  }

  .br-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), 0 8px 32px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .br-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .br-card-period {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--br-green);
    background: rgba(26, 92, 42, 0.08);
    border: 1px solid rgba(26, 92, 42, 0.2);
    border-radius: 100px;
    padding: 3px 12px;
  }

  .br-card-era {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    color: var(--br-muted);
    font-weight: 400;
  }

  .br-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--br-text);
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .br-card-summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    line-height: 1.75;
    color: #4b4540;
    margin: 0 0 16px;
    font-weight: 400;
  }

  .br-card-content {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    line-height: 1.85;
    color: #374150;
    border-top: 1px solid var(--br-border);
    padding-top: 14px;
    margin-bottom: 14px;
  }

  .br-card-content p { margin: 0; }

  .br-card-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--br-green-mid);
    padding: 0;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .br-card-toggle:hover {
    color: var(--br-gold-dark);
  }

  .br-toggle-icon {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.25s;
    position: relative;
  }

  .br-toggle-icon::before,
  .br-toggle-icon::after {
    content: '';
    position: absolute;
    background: white;
    border-radius: 2px;
  }
  .br-toggle-icon::before {
    width: 7px; height: 1.5px;
  }
  .br-toggle-icon::after {
    width: 1.5px; height: 7px;
    transition: transform 0.25s;
  }

  .br-card-toggle[aria-expanded="true"] .br-toggle-icon::after {
    transform: rotate(90deg);
  }

  /* ── Footer ─────────────────────────────────── */
  .br-footer {
    background: var(--br-green-dark);
    padding: 48px 24px;
  }

  .br-footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .br-footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--br-gold);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .br-footer-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: rgba(242, 201, 76, 0.3);
    margin: 0;
  }

  .br-footer-back {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--br-gold);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .br-footer-back:hover {
    color: var(--br-white);
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 640px) {
    .br-timeline-line { left: 16px; }

    .br-card-wrap.left,
    .br-card-wrap.right {
      flex-direction: column;
      padding-left: 44px;
      padding-right: 0;
    }

    .br-card-wrap.left .br-card { text-align: left; }
    .br-card-wrap.left .br-card-top { justify-content: flex-start; }
    .br-card-wrap.left .br-card-toggle { margin-left: 0; }

    .br-timeline-node {
      left: 16px;
      top: 18px;
    }

    .br-tab-label { display: none; }
    .br-tab { padding: 14px 16px; }
    .br-tab-icon { font-size: 1.1rem; }

    .br-pillar-header { flex-direction: column; align-items: flex-start; gap: 8px; }
    .br-pillar-icon-lg { display: none; }

    .br-hero-stats { gap: 20px; }
    .br-stat-divider { height: 28px; }

    .br-footer-inner { flex-direction: column; text-align: center; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.br-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.br-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const target = tab.dataset.pillar;
      document.querySelectorAll('.br-pillar').forEach(p => {
        const active = p.id === `pillar-${target}`;
        p.classList.toggle('active', active);
        p.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      observeCards();
    });
  });

  // Expand / collapse
  document.querySelectorAll('.br-card-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.closest('.br-card').querySelector('.br-card-content');
      const open = btn.getAttribute('aria-expanded') === 'true';
      content.hidden = open;
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      btn.querySelector('.br-toggle-text').textContent = open ? 'Read more' : 'Read less';
    });
  });

  // Scroll animation
  let observer;
  function observeCards() {
    if (observer) observer.disconnect();
    observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });

    document.querySelectorAll('.br-pillar.active .br-card-wrap:not(.visible)')
      .forEach(c => observer.observe(c));
  }

  observeCards();
</script>
